/* pages/index/index.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
  padding: 20rpx;
}

/* 状态栏背景 */
.status-bar-bg {
  height: 80rpx;
  background: transparent;
}

/* 用户信息卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  flex: 1;
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.user-greeting {
  font-size: 28rpx;
  color: #86868b;
}

.streak-badge {
  background: linear-gradient(135deg, #ff9500 0%, #ff5e3a 100%);
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
}

.streak-days {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  line-height: 1;
}

.streak-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* 学习数据统计 */
.stats-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(242, 242, 247, 0.8);
  border-radius: 20rpx;
  padding: 32rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.stat-number.highlight {
  color: #ff3b30;
}

.stat-title {
  font-size: 28rpx;
  color: #86868b;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.1);
}

/* 欢迎卡片 */
.welcome-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 32rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.3);
}

.welcome-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.app-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  backdrop-filter: blur(10px);
}

.icon-text {
  font-size: 60rpx;
}

.welcome-title {
  font-size: 56rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.login-button {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.button-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-right: 16rpx;
}

.button-icon {
  font-size: 28rpx;
  color: #1d1d1f;
}

/* 功能区域 */
.features-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
  display: block;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.feature-card {
  background: #5ac8fa;
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s ease;
}

.feature-card:active {
  transform: scale(0.95);
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  display: block;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 500;
  color: white;
  display: block;
}

/* 复习提醒卡片 */
.reminder-card {
  background: linear-gradient(135deg, #ff9500 0%, #ff5e3a 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 149, 0, 0.3);
}

.reminder-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.reminder-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  color: white;
}

.reminder-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.reminder-title {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 4rpx;
}

.reminder-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.reminder-count {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
}

.reminder-message {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 32rpx;
  line-height: 1.4;
  display: block;
}

.reminder-button {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: none;
}

.reminder-button .button-text {
  color: #ff9500;
}

/* 最近添加的生词 */
.recent-words-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.see-all {
  font-size: 28rpx;
  color: #007aff;
  font-weight: 500;
}

.words-scroll {
  white-space: nowrap;
}

.words-list {
  display: inline-flex;
  gap: 20rpx;
}

.word-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  min-width: 280rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: inline-flex;
  flex-direction: column;
}

.word-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 8rpx;
  display: block;
}

.word-meaning {
  font-size: 28rpx;
  color: #86868b;
  margin-bottom: 16rpx;
  display: block;
}

.word-status {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
}

.status-text {
  display: block;
}

/* 学习建议 */
.tips-section {
  margin-bottom: 40rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.tip-item {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 30rpx;
  color: #1d1d1f;
  line-height: 1.4;
  flex: 1;
  display: block;
}