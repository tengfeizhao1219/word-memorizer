<!-- pages/login/login.wxml -->
<view class="login-container">
  <!-- 背景装饰 -->
  <view class="background-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>
  
  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- 应用图标和标题 -->
    <view class="app-header">
      <view class="app-icon">
        <text class="icon-text">📚</text>
      </view>
      <text class="app-title">生词本</text>
      <text class="app-subtitle">科学记忆，高效学习</text>
    </view>
    
    <!-- 登录表单 -->
    <view class="login-form">
      <!-- 微信登录按钮 -->
      <button class="wechat-login-btn" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
        <image class="wechat-icon" src="/static/images/wechat-icon.png"></image>
        <text class="btn-text">微信一键登录</text>
      </button>
      
      <!-- 分割线 -->
      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">或</text>
        <view class="divider-line"></view>
      </view>
      
      <!-- 手机号登录 -->
      <view class="phone-login-section">
        <button class="phone-login-btn" bindtap="showPhoneLogin">
          <text class="btn-text">手机号登录</text>
        </button>
        <text class="phone-tip">首次使用需要绑定手机号</text>
      </view>
    </view>
    
    <!-- 服务条款 -->
    <view class="terms-section">
      <checkbox class="terms-checkbox" checked="{{agreeTerms}}" bindtap="toggleTerms" />
      <text class="terms-text">我已阅读并同意</text>
      <text class="terms-link" bindtap="showTerms">《用户协议》</text>
      <text class="terms-text">和</text>
      <text class="terms-link" bindtap="showPrivacy">《隐私政策》</text>
    </view>
    
    <!-- 游客模式 -->
    <view class="guest-section" wx:if="{{!isLoggingIn}}">
      <text class="guest-text">先体验一下？</text>
      <text class="guest-link" bindtap="enterGuestMode">游客模式进入</text>
    </view>
  </view>
  
  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">版本 1.0.0</text>
    <text class="footer-text">© 2026 生词本团队</text>
  </view>
</view>