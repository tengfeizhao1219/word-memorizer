/* 单词本学习系统 - 全局样式 */
/* 基于 https://tengfeizhao1219.github.io/WordMemeray/ UI设计，2026-03-22更新 */

/* ============================================
   设计系统变量 (基于WordMemeray设计)
   ============================================ */

/* 色彩系统 - 基于WordMemeray设计 */
:root {
  /* 主色调 - 紫色系 */
  --primary-50: #f5f3ff;    /* 最浅紫色 */
  --primary-100: #ede9fe;   /* 浅紫色 */
  --primary-200: #ddd6fe;   /* 淡紫色 */
  --primary-300: #c4b5fd;   /* 中等紫色 */
  --primary-400: #a78bfa;   /* 紫色 */
  --primary-500: #7c3aed;   /* 品牌紫色 - 来自设计 */
  --primary-600: #6d28d9;   /* 深紫色 */
  --primary-700: #5b21b6;   /* 更深紫色 */
  --primary-800: #4c1d95;   /* 暗紫色 */
  --primary-900: #3c166b;   /* 最深紫色 */
  
  /* 辅助色 - 基于设计中的其他颜色 */
  --secondary: #f59e0b;     /* 橙色 - 来自设计 */
  --success: #10b981;       /* 绿色 */
  --error: #ef4444;         /* 红色 */
  --info: #3b82f6;          /* 蓝色 */
  --warning: #f59e0b;       /* 橙色 */
  
  /* 中性色 - 基于设计中的文字颜色 */
  --gray-50: #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;      /* 中等灰色 */
  --gray-600: #4b5563;      /* 深灰色 */
  --gray-700: #374151;      /* 更深灰色 */
  --gray-800: #1f2937;      /* 接近设计中的文字颜色 */
  --gray-900: #111827;      /* 最深灰色 */
  
  /* 背景色 - 基于设计 */
  --bg-primary: #ffffff;                    /* 白色背景 */
  --bg-secondary: rgb(245, 243, 255);       /* 淡紫色背景 - 来自设计 */
  --bg-tertiary: #f9fafb;                   /* 浅灰色背景 */
  
  /* 文本色 - 基于设计 */
  --text-primary: rgb(31, 41, 55);          /* 深灰色文字 - 来自设计 */
  --text-secondary: #6b7280;                /* 中等灰色文字 */
  --text-tertiary: #9ca3af;                 /* 浅灰色文字 */
  --text-inverse: #ffffff;                  /* 白色文字 */
  
  /* 边框色 - 基于设计中的按钮边框 */
  --border-light: #e5e7eb;                  /* 浅灰色边框 */
  --border-medium: #d1d5db;                 /* 中等灰色边框 */
  --border-dark: #9ca3af;                   /* 深灰色边框 */
  --border-primary: #7c3aed;                /* 紫色边框 - 来自设计 */
  --border-secondary: #ddd6fe;              /* 淡紫色边框 */
}

/* 字体系统 - 基于WordMemeray设计 */
:root {
  /* 字体 */
  --font-family: "PingFang SC", "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
  
  /* 字体大小 (rpx) - 基于16px基础大小换算 */
  --text-xs: 24rpx;      /* 12px */
  --text-sm: 28rpx;      /* 14px */
  --text-base: 32rpx;    /* 16px - 基础大小 */
  --text-lg: 36rpx;      /* 18px */
  --text-xl: 40rpx;      /* 20px */
  --text-2xl: 48rpx;     /* 24px */
  --text-3xl: 56rpx;     /* 28px */
  --text-4xl: 64rpx;     /* 32px */
  
  /* 字重 - 基于设计 */
  --font-normal: 400;
  --font-medium: 500;
  --font-semibold: 600;
  --font-bold: 700;
  
  /* 行高 */
  --leading-none: 1;
  --leading-tight: 1.25;
  --leading-normal: 1.5;
  --leading-relaxed: 1.75;
  --leading-loose: 2;
}

/* 间距系统 - 基于WordMemeray设计 */
:root {
  --space-0: 0;
  --space-1: 8rpx;      /* 4px */
  --space-2: 16rpx;     /* 8px */
  --space-3: 24rpx;     /* 12px */
  --space-4: 32rpx;     /* 16px */
  --space-5: 40rpx;     /* 20px */
  --space-6: 48rpx;     /* 24px */
  --space-8: 64rpx;     /* 32px */
  --space-10: 80rpx;    /* 40px */
  --space-12: 96rpx;    /* 48px */
  --space-16: 128rpx;   /* 64px */
  --space-20: 160rpx;   /* 80px */
}

/* 圆角系统 - 基于WordMemeray设计（按钮圆角20px = 40rpx） */
:root {
  --radius-none: 0;
  --radius-sm: 8rpx;     /* 4px */
  --radius-md: 16rpx;    /* 8px */
  --radius-lg: 24rpx;    /* 12px */
  --radius-xl: 32rpx;    /* 16px */
  --radius-2xl: 40rpx;   /* 20px - 设计中的按钮圆角 */
  --radius-3xl: 48rpx;   /* 24px */
  --radius-full: 9999rpx; /* 完全圆形 */
}
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-2xl: 48rpx;
  --radius-full: 9999rpx;
}

/* 阴影系统 */
:root {
  --shadow-xs: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  --shadow-sm: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  --shadow-xl: 0 24rpx 64rpx rgba(0, 0, 0, 0.2);
  --shadow-inner: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}

/* 动效系统 */
:root {
  --transition-fast: 150ms;
  --transition-normal: 300ms;
  --transition-slow: 500ms;
  --transition-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* ============================================
   基础重置 (Base Reset)
   ============================================ */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  color: var(--text-primary);
  background-color: var(--bg-secondary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 移除默认边距 */
view, text, image, button, input, textarea {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* 链接样式 */
navigator {
  color: var(--primary-600);
  text-decoration: none;
  transition: color var(--transition-fast);
}

navigator:hover {
  color: var(--primary-700);
}

/* ============================================
   工具类 (Utility Classes)
   ============================================ */

