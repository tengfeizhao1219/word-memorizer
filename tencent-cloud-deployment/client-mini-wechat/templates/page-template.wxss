/* 页面模板样式 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: var(--bg-secondary);
  position: relative;
}

/* 页面头部 */
.page-header {
  background: var(--bg-primary);
  border-bottom: 1rpx solid var(--border-light);
  padding: var(--space-4) var(--space-5);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow-sm);
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}

/* 返回按钮 */
.back-btn {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
  flex-shrink: 0;
}

.back-btn:hover, .back-btn.hover {
  background: var(--bg-tertiary);
}

.back-icon {
  font-size: 32rpx;
  color: var(--text-primary);
}

.back-text {
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: var(--font-medium);
}

/* 标题区域 */
.title-area {
  flex: 1;
  text-align: center;
}

.page-title {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.page-subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
}

/* 操作按钮区域 */
.header-actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

/* 页面内容 */
.page-content {
  padding: var(--space-5);
  min-height: 60vh;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-content {
  text-align: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--gray-300);
  border-top-color: var(--primary-500);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto var(--space-4);
}

.loading-text {
  font-size: var(--text-base);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 错误状态 */
.error-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.error-content {
  text-align: center;
  max-width: 400rpx;
}

.error-icon {
  font-size: 64rpx;
  color: var(--error);
  display: block;
  margin-bottom: var(--space-4);
}

.error-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
}

.error-desc {
  font-size: var(--text-base);
  color: var(--text-secondary);
  display: block;
  margin-bottom: var(--space-6);
  line-height: var(--leading-relaxed);
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-content {
  text-align: center;
  max-width: 400rpx;
}

.empty-icon {
  font-size: 64rpx;
  color: var(--gray-400);
  display: block;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  color: var(--gray-700);
  display: block;
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--text-base);
  color: var(--gray-600);
  display: block;
  margin-bottom: var(--space-6);
  line-height: var(--leading-relaxed);
}

/* 正常内容 */
.normal-content {
  animation: fadeIn 0.5s var(--transition-spring);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 页面底部 */
.page-footer {
  padding: var(--space-5);
  background: var(--bg-primary);
  border-top: 1rpx solid var(--border-light);
  margin-top: auto;
}

/* 浮动操作按钮 */
.fab-container {
  position: fixed;
  bottom: var(--space-8);
  right: var(--space-5);
  z-index: 1000;
}

/* 全局提示 */
.toast-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2000;
  pointer-events: none;
}

.toast {
  background: rgba(0, 0, 0, 0.85);
  color: var(--text-inverse);
  padding: var(--space-4) var(--space-5);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: var(--space-3);
  box-shadow: var(--shadow-xl);
  animation: toastSlideIn 0.3s var(--transition-spring),
             toastFadeOut 0.3s var(--transition-spring) 2.7s forwards;
  max-width: 600rpx;
}

.toast.success {
  background: rgba(16, 185, 129, 0.95);
}

.toast.error {
  background: rgba(239, 68, 68, 0.95);
}

.toast.warning {
  background: rgba(245, 158, 11, 0.95);
}

.toast.info {
  background: rgba(59, 130, 246, 0.95);
}

.toast-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.toast-text {
  font-size: var(--text-base);
  font-weight: var(--font-medium);
  flex: 1;
}

@keyframes toastSlideIn {
  from {
    opacity: 0;
    transform: translate(-50%, -60%);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
}

@keyframes toastFadeOut {
  from {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
  to {
    opacity: 0;
    transform: translate(-50%, -40%);
  }
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3000;
  animation: fadeIn 0.3s ease;
}

.modal-content {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: var(--shadow-2xl);
  animation: modalSlideIn 0.3s var(--transition-spring);
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.modal-header {
  padding: var(--space-5);
  border-bottom: 1rpx solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.modal-close {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-tertiary);
  transition: all var(--transition-fast);
}

.modal-close:hover {
  background: var(--bg-secondary);
}

.close-icon {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: var(--font-bold);
}

.modal-body {
  padding: var(--space-5);
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  padding: var(--space-4) var(--space-5);
  border-top: 1rpx solid var(--border-light);
  background: var(--bg-tertiary);
  display: flex;
  justify-content: flex-end;
  gap: var(--space-3);
}

/* 响应式调整 */
@media screen and (max-width: 600rpx) {
  .page-header {
    padding: var(--space-3) var(--space-4);
  }
  
  .page-content {
    padding: var(--space-4);
  }
  
  .page-footer {
    padding: var(--space-4);
  }
  
  .fab-container {
    bottom: var(--space-6);
    right: var(--space-4);
  }
  
  .modal-content {
    width: 95%;
  }
  
  .modal-header {
    padding: var(--space-4);
  }
  
  .modal-body {
    padding: var(--space-4);
  }
  
  .modal-footer {
    padding: var(--space-3) var(--space-4);
  }
}

@media screen and (min-width: 900rpx) {
  .page-container {
    max-width: 900rpx;
    margin: 0 auto;
  }
  
  .modal-content {
    max-width: 700rpx;
  }
}