/* 首页样式 - 基于WordMemeray设计 */

/* 页面容器 */
.wordmemeray-container {
  min-height: 100vh;
  background: var(--bg-secondary); /* 淡紫色背景 */
  font-family: var(--font-family);
  padding-bottom: 120rpx; /* 为底部导航留出空间 */
}

/* 头部区域 */
.header-section {
  background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-700) 100%);
  color: var(--text-inverse);
  padding: var(--space-8) var(--space-5) var(--space-6);
  border-bottom-left-radius: var(--radius-2xl);
  border-bottom-right-radius: var(--radius-2xl);
  box-shadow: var(--shadow-md);
}

.header-content {
  text-align: center;
}

.app-title {
  font-size: var(--text-3xl);
  font-weight: var(--font-bold);
  display: block;
  margin-bottom: var(--space-2);
}

.app-subtitle {
  font-size: var(--text-base);
  opacity: 0.9;
  display: block;
}

/* 主要内容区域 */
.main-section {
  padding: var(--space-5);
}

/* 卡片通用样式 */
.query-card,
.quick-actions-card,
.stats-card,
.recent-card {
  background: var(--bg-primary);
  border-radius: var(--radius-2xl);
  margin-bottom: var(--space-5);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-secondary);
  overflow: hidden;
}

.card-header {
  padding: var(--space-5) var(--space-5) var(--space-4);
  border-bottom: 1rpx solid var(--border-light);
}

.card-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.card-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
}

/* 查询卡片 */
.query-input-section {
  padding: var(--space-5);
}

.query-input {
  width: 100%;
  padding: var(--space-4);
  background: var(--bg-tertiary);
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-2xl);
  font-size: var(--text-base);
  color: var(--text-primary);
  margin-bottom: var(--space-4);
  transition: all var(--transition-fast);
}

.query-input:focus {
  border-color: var(--primary-400);
  box-shadow: 0 0 0 3rpx rgba(124, 58, 237, 0.1);
  outline: none;
}

.query-input::placeholder {
  color: var(--text-tertiary);
}

.query-actions {
  display: flex;
  gap: var(--space-3);
}

.action-btn {
  flex: 1;
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-2xl);
  font-size: var(--text-base);
  font-weight: var(--font-medium);
  border: none;
  transition: all var(--transition-fast);
}

.clear-btn {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-light);
}

.search-btn {
  background: var(--primary-500);
  color: var(--text-inverse);
  border: 2rpx solid var(--primary-500);
}

.search-btn:disabled {
  background: var(--gray-300);
  border-color: var(--gray-300);
  color: var(--gray-500);
  cursor: not-allowed;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

/* 查询结果 */
.query-result {
  padding: var(--space-5);
  border-top: 1rpx solid var(--border-light);
  background: var(--bg-tertiary);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-4);
}

.result-title {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.add-word-btn {
  padding: var(--space-2) var(--space-3);
  background: var(--primary-100);
  color: var(--primary-600);
  border: 2rpx solid var(--primary-300);
  border-radius: var(--radius-xl);
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
}

.result-content {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  border: 1rpx solid var(--border-light);
}

.word-display {
  margin-bottom: var(--space-4);
}

.word-english {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--primary-600);
  display: block;
  margin-bottom: var(--space-1);
}

.word-chinese {
  font-size: var(--text-lg);
  color: var(--text-primary);
  display: block;
}

.word-details,
.word-example {
  margin-top: var(--space-3);
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--border-light);
}

.details-label,
.example-label {
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  color: var(--text-secondary);
  display: block;
  margin-bottom: var(--space-1);
}

.details-content,
.example-content {
  font-size: var(--text-base);
  color: var(--text-primary);
  line-height: var(--leading-relaxed);
  display: block;
}

/* 快速功能卡片 */
.quick-actions-card .card-header {
  border-bottom: none;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
  padding: var(--space-4) var(--space-5) var(--space-5);
}

.action-item {
  text-align: center;
  padding: var(--space-3);
  border-radius: var(--radius-xl);
  background: var(--bg-tertiary);
  border: 1rpx solid var(--border-light);
  transition: all var(--transition-fast);
}

.item-hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
  border-color: var(--primary-300);
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-2);
}

.translate-icon {
  background: rgba(124, 58, 237, 0.1);
  color: var(--primary-500);
}

.wordbook-icon {
  background: rgba(16, 185, 129, 0.1);
  color: var(--success);
}

.review-icon {
  background: rgba(245, 158, 11, 0.1);
  color: var(--warning);
}

.reminder-icon {
  background: rgba(59, 130, 246, 0.1);
  color: var(--info);
}

.action-icon .icon {
  font-size: 28rpx;
}

.action-text {
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.action-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
}

/* 统计卡片 */
.stats-content {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
  padding: var(--space-4) var(--space-5);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: var(--text-2xl);
  font-weight: var(--font-bold);
  color: var(--primary-600);
  display: block;
  margin-bottom: var(--space-1);
}

.stat-label {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  display: block;
}

.progress-section {
  padding: var(--space-4) var(--space-5) var(--space-5);
  border-top: 1rpx solid var(--border-light);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.progress-title {
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  color: var(--text-secondary);
}

.progress-percent {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

.progress-bar {
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-400), var(--primary-600));
  border-radius: var(--radius-full);
  transition: width 0.5s var(--transition-spring);
}

/* 最近学习卡片 */
.recent-list {
  white-space: nowrap;
  padding: var(--space-4) var(--space-5) var(--space-5);
}

.recent-scroll {
  display: inline-flex;
  gap: var(--space-3);
}

.recent-item {
  width: 240rpx;
  padding: var(--space-3);
  background: var(--bg-tertiary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-xl);
  display: inline-flex;
  flex-direction: column;
  white-space: normal;
}

.word-content {
  margin-bottom: var(--space-2);
}

.word-text {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.word-translation {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
}

.word-time {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  text-align: right;
}

/* 空状态 */
.empty-state {
  padding: var(--space-10) var(--space-5);
  text-align: center;
}

.empty-content {
  max-width: 400rpx;
  margin: 0 auto;
}

.empty-icon {
  font-size: 64rpx;
  color: var(--gray-400);
  display: block;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--gray-700);
  display: block;
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--text-base);
  color: var(--gray-600);
  display: block;
  margin-bottom: var(--space-6);
  line-height: var(--leading-relaxed);
}

.empty-action-btn {
  padding: var(--space-3) var(--space-5);
  background: var(--primary-500);
  color: var(--text-inverse);
  border: none;
  border-radius: var(--radius-2xl);
  font-size: var(--text-base);
  font-weight: var(--font-medium);
}

/* 底部导航栏 - 基于WordMemeray设计 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-primary);
  border-top: 1rpx solid var(--border-light);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: var(--space-3) 0;
  z-index: 1000;
  box-shadow: var(--shadow-lg);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2);
  flex: 1;
  transition: all var(--transition-fast);
}

.nav-item.active {
  color: var(--primary-500);
}

.nav-item.active .nav-icon {
  background: var(--primary-100);
  border-color: var(--primary-300);
  transform: translateY(-4rpx);
}

.nav-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
  transition: all var(--transition-fast);
  background: var(--bg-tertiary);
}

.nav-icon .icon {
  font-size: 24rpx;
}

.nav-text {
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
}

/* 登录提示 */
.login-prompt {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  padding: var(--space-5);
}

.login-card {
  background: var(--bg-primary);
  border-radius: var(--radius-2xl);
  padding: var(--space-6);
  text-align: center;
  max-width: 500rpx;
  width: 100%;
  box-shadow: var(--shadow-xl);
}

.login-title {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
}

.login-desc {
  font-size: var(--text-base);
  color: var(--text-secondary);
  display: block;
  margin-bottom: var(--space-6);
  line-height: var(--leading-relaxed);
}

.login-btn {
  width: 100%;
  padding: var(--space-4);
  background: var(--primary-500);
  color: var(--text-inverse);
  border: none;
  border-radius: var(--radius-2xl);
  font-size: var(--text-base);
  font-weight: var(--font-bold);
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.query-card,
.quick-actions-card,
.stats-card,
.recent-card {
  animation: fadeInUp 0.5s var(--transition-spring) forwards;
  opacity: 0;
}

.query-card { animation-delay: 0.1s; }
.quick-actions-card { animation-delay: 0.2s; }
.stats-card { animation-delay: 0.3s; }
.recent-card { animation-delay: 0.4s; }

/* 响应式调整 */
@media screen and (max-width: 600rpx) {
  .main-section {
    padding: var(--space-4);
  }
  
  .actions-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  
  .stats-content {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  
  .recent-item {
    width: 200rpx;
  }
  
  .query-actions {
    flex-direction: column;
  }
}

@media screen and (min-width: 900rpx) {
  .wordmemeray-container {
    max-width: 900rpx;
    margin: 0 auto;
  }
}