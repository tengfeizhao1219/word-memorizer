/* 首页样式 - 单词本学习系统 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--primary-50) 0%, var(--bg-secondary) 100%);
  padding-bottom: 120rpx;
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  background: var(--bg-primary);
  border-bottom: 1rpx solid var(--border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left .app-name {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

.nav-right .btn {
  padding: var(--space-2);
}

.nav-right .icon {
  font-size: 32rpx;
}

/* 用户欢迎区域 */
.welcome-section {
  padding: var(--space-5);
}

.welcome-card {
  background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-700) 100%);
  color: var(--text-inverse);
  border: none;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-5);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  margin-right: var(--space-4);
}

.user-details {
  flex: 1;
}

.greeting {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  display: block;
  margin-bottom: var(--space-1);
}

.subtitle {
  font-size: var(--text-sm);
  opacity: 0.9;
  display: block;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: var(--space-4);
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: var(--text-2xl);
  font-weight: var(--font-bold);
  display: block;
  margin-bottom: var(--space-1);
}

.stat-label {
  font-size: var(--text-xs);
  opacity: 0.8;
  display: block;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 快速操作区域 */
.quick-actions-section {
  padding: 0 var(--space-5) var(--space-5);
}

.section-header {
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.section-subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
}

.actions-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}

.action-card {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  transition: all var(--transition-normal);
}

.action-card:active {
  transform: translateY(-4rpx);
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-4);
  flex-shrink: 0;
}

.action-icon .icon {
  font-size: 28rpx;
}

.action-content {
  flex: 1;
}

.action-title {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.action-desc {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  display: block;
}

.action-arrow {
  color: var(--text-tertiary);
  font-size: 20rpx;
  margin-left: var(--space-2);
}

/* 今日目标区域 */
.goal-section {
  padding: 0 var(--space-5) var(--space-5);
}

.goal-card {
  padding: var(--space-5);
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-4);
}

.goal-title {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.goal-progress {
  text-align: right;
}

.progress-text {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
}

.progress-percent {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--primary-600);
  display: block;
}

.progress-bar {
  height: 12rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: var(--space-5);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-400), var(--primary-600));
  border-radius: var(--radius-full);
  transition: width 0.5s var(--transition-spring);
}

.goal-actions {
  text-align: center;
}

.goal-completed {
  text-align: center;
  padding: var(--space-3);
}

.completed-text {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--success);
}

/* 最近学习区域 */
.recent-section {
  padding: 0 var(--space-5) var(--space-5);
}

.recent-list {
  white-space: nowrap;
}

.recent-scroll {
  display: inline-flex;
  gap: var(--space-4);
}

.recent-word-card {
  width: 280rpx;
  padding: var(--space-4);
  display: inline-flex;
  flex-direction: column;
  white-space: normal;
}

.word-main {
  margin-bottom: var(--space-3);
}

.word-text {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.word-translation {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
}

.word-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.word-time {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.word-tag {
  background: rgba(239, 68, 68, 0.1);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-full);
}

.tag-text {
  font-size: 20rpx;
  color: var(--error);
  font-weight: var(--font-medium);
}

/* 学习统计区域 */
.stats-section {
  padding: 0 var(--space-5) var(--space-5);
}

.stats-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}

.stat-card {
  padding: var(--space-4);
  text-align: center;
  transition: all var(--transition-fast);
}

.stat-card:active {
  transform: translateY(-2rpx);
}

.stat-card-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: var(--space-2);
}

.stat-card-title {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-1);
}

.stat-card-desc {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  display: block;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-primary);
  border-top: 1rpx solid var(--border-light);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: var(--space-3) 0;
  z-index: 1000;
  box-shadow: var(--shadow-lg);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2);
  flex: 1;
  transition: all var(--transition-fast);
}

.nav-item.active {
  color: var(--primary-600);
}

.nav-item.active .nav-icon {
  transform: translateY(-4rpx);
}

.nav-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
  transition: transform var(--transition-fast);
}

.nav-text {
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
}

.add-button {
  position: relative;
  margin: 0 var(--space-4);
}

.add-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary-400), var(--primary-600));
  color: var(--text-inverse);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-fast);
}

.add-button:active .add-icon {
  transform: scale(0.95);
  box-shadow: var(--shadow-sm);
}

/* 登录提示 */
.login-prompt {
  padding: var(--space-5);
}

.login-card {
  padding: var(--space-6);
  text-align: center;
}

.login-title {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
}

.login-desc {
  font-size: var(--text-base);
  color: var(--text-secondary);
  display: block;
  margin-bottom: var(--space-6);
  line-height: var(--leading-relaxed);
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.welcome-card,
.action-card,
.goal-card,
.recent-word-card,
.stat-card {
  animation: fadeInUp 0.5s var(--transition-spring) forwards;
}

.action-card:nth-child(1) { animation-delay: 0.1s; }
.action-card:nth-child(2) { animation-delay: 0.2s; }
.action-card:nth-child(3) { animation-delay: 0.3s; }
.action-card:nth-child(4) { animation-delay: 0.4s; }

/* 响应式调整 */
@media screen and (max-width: 600rpx) {
  .actions-grid {
    grid-template-columns: 1fr;
  }
  
  .stats-cards {
    grid-template-columns: 1fr;
  }
  
  .recent-word-card {
    width: 240rpx;
  }
}

@media screen and (min-width: 900rpx) {
  .page-container {
    max-width: 900rpx;
    margin: 0 auto;
  }
}

/* 加载状态 */
.loading-state {
  padding: var(--space-10);
  text-align: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--gray-300);
  border-top-color: var(--primary-500);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto var(--space-4);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: var(--space-10) var(--space-5);
}

.empty-icon {
  font-size: 64rpx;
  color: var(--gray-400);
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  color: var(--gray-700);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--text-base);
  color: var(--gray-600);
  margin-bottom: var(--space-6);
}