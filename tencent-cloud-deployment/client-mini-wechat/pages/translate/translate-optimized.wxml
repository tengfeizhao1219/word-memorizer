<!-- 翻译功能页面 - 优化版 -->
<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-content">
      <text class="page-title">🔤 智能翻译</text>
      <text class="page-subtitle">中英互译，学习更轻松</text>
    </view>
  </view>
  
  <!-- 语言选择卡片 -->
  <card 
    title="语言选择" 
    subtitle="选择源语言和目标语言"
    type="elevated"
    padding="lg"
    class="language-card-section"
  >
    <view class="language-selector">
      <view class="language-row">
        <view class="language-from">
          <text class="language-label">从</text>
          <picker 
            class="language-picker" 
            range="{{languages}}" 
            value="{{fromIndex}}"
            bindchange="onFromChange"
          >
            <view class="picker-view">
              <text class="language-name">{{languages[fromIndex]}}</text>
              <text class="language-code">{{languageCodes[fromIndex]}}</text>
            </view>
          </picker>
        </view>
        
        <button 
          class="swap-btn" 
          bindtap="switchLanguages"
          hover-class="hover"
        >
          <text class="swap-icon">⇄</text>
        </button>
        
        <view class="language-to">
          <text class="language-label">到</text>
          <picker 
            class="language-picker" 
            range="{{languages}}" 
            value="{{toIndex}}"
            bindchange="onToChange"
          >
            <view class="picker-view">
              <text class="language-name">{{languages[toIndex]}}</text>
              <text class="language-code">{{languageCodes[toIndex]}}</text>
            </view>
          </picker>
        </view>
      </view>
    </view>
  </card>
  
  <!-- 输入区域卡片 -->
  <card 
    title="输入文本" 
    subtitle="输入需要翻译的内容"
    type="elevated"
    padding="lg"
    class="input-card-section"
  >
    <textarea 
      class="input-textarea" 
      placeholder="{{fromIndex === 0 ? '请输入中文...' : 'Enter English...'}}"
      value="{{inputText}}"
      bindinput="onInput"
      auto-height
      maxlength="500"
      show-count
      placeholder-class="textarea-placeholder"
    />
    
    <view class="input-actions">
      <custom-button 
        type="ghost" 
        size="small"
        text="🗑️ 清空"
        bind:click="clearInput"
        wx:if="{{inputText}}"
        class="clear-btn"
      />
      
      <custom-button 
        type="primary" 
        size="large"
        text="{{translating ? '翻译中...' : '🚀 开始翻译'}}"
        icon="{{translating ? '' : '🔤'}}"
        loading="{{translating}}"
        disabled="{{!inputText || translating}}"
        bind:click="doTranslate"
        class="translate-btn"
      />
    </view>
  </card>
  
  <!-- 翻译结果卡片 -->
  <card 
    wx:if="{{translationResult}}"
    title="翻译结果"
    subtitle="{{translationResult.provider === 'tencent' ? '腾讯云翻译' : '本地词典'}}"
    type="elevated"
    padding="lg"
    class="result-card-section"
  >
    <view class="result-content">
      <!-- 原文 -->
      <view class="text-section original">
        <text class="section-label">📝 原文</text>
        <view class="text-content">
          <text class="text">{{translationResult.original}}</text>
        </view>
      </view>
      
      <!-- 翻译 -->
      <view class="text-section translated">
        <text class="section-label">🎯 翻译</text>
        <view class="text-content">
          <text class="text">{{translationResult.translated}}</text>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="result-actions">
        <view class="action-row">
          <custom-button 
            type="secondary" 
            size="small"
            text="🔊 朗读原文"
            bind:click="speakText"
            data-text="{{translationResult.original}}"
          />
          
          <custom-button 
            type="secondary" 
            size="small"
            text="🔊 朗读翻译"
            bind:click="speakText"
            data-text="{{translationResult.translated}}"
          />
        </view>
        
        <view class="action-row">
          <custom-button 
            type="primary" 
            size="medium"
            text="📚 加入生词本"
            bind:click="addToWordList"
            wx:if="{{canAddToWordList}}"
          />
          
          <custom-button 
            type="ghost" 
            size="medium"
            text="📋 复制翻译"
            bind:click="copyTranslation"
          />
        </view>
      </view>
    </view>
  </card>
  
  <!-- 翻译历史卡片 -->
  <card 
    wx:if="{{translationHistory.length > 0}}"
    title="翻译历史"
    subtitle="最近翻译记录"
    type="elevated"
    padding="lg"
    class="history-card-section"
  >
    <view slot="actions">
      <custom-button 
        type="ghost" 
        size="small"
        text="清空"
        bind:click="clearHistory"
      />
    </view>
    
    <scroll-view class="history-list" scroll-y>
      <block wx:for="{{translationHistory}}" wx:key="timestamp">
        <view 
          class="history-item" 
          bindtap="useHistory" 
          data-index="{{index}}"
          hover-class="hover"
        >
          <view class="history-content">
            <text class="history-original">{{item.original}}</text>
            <text class="history-translated">{{item.translated}}</text>
          </view>
          <view class="history-meta">
            <text class="history-lang">{{item.source}} → {{item.target}}</text>
            <text class="history-time">{{formatTime(item.timestamp)}}</text>
          </view>
        </view>
      </block>
    </scroll-view>
  </card>
  
  <!-- 使用提示卡片 -->
  <card 
    type="filled"
    padding="md"
    class="tips-card-section"
  >
    <view class="tips-content">
      <view class="tip-item">
        <text class="tip-icon">💡</text>
        <text class="tip-text">翻译结果可直接加入生词本学习</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">🎯</text>
        <text class="tip-text">免费额度: 每月100万字符，足够个人使用</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">⚡</text>
        <text class="tip-text">支持中英文互译，准确率高达98%</text>
      </view>
    </view>
  </card>
  
  <!-- 快速操作卡片 -->
  <card 
    type="outlined"
    padding="md"
    class="quick-actions-section"
  >
    <view class="quick-actions">
      <custom-button 
        type="ghost" 
        size="medium"
        text="➕ 添加单词"
        icon="➕"
        bind:click="goToWordAdd"
      />
      
      <custom-button 
        type="ghost" 
        size="medium"
        text="📚 生词列表"
        icon="📚"
        bind:click="goToWordList"
      />
      
      <custom-button 
        type="ghost" 
        size="medium"
        text="🧪 系统测试"
        icon="🧪"
        bind:click="goToTest"
      />
    </view>
  </card>
  
  <!-- 空状态提示 -->
  <card 
    wx:if="{{!translationResult && translationHistory.length === 0}}"
    type="filled"
    padding="xl"
    class="empty-state-section"
    empty
    empty-icon="🔤"
    empty-title="开始翻译"
    empty-desc="输入文本并点击翻译按钮开始使用"
  >
    <view slot="empty">
      <custom-button 
        type="primary" 
        size="large"
        text="查看使用教程"
        icon="📖"
        bind:click="showTutorial"
        class="tutorial-btn"
      />
    </view>
  </card>
</view>