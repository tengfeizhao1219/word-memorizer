/* 按钮组件样式 */

.custom-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: none;
  outline: none;
  cursor: pointer;
  transition: all var(--transition-fast);
  font-family: inherit;
  line-height: 1;
  position: relative;
  overflow: hidden;
}

/* 按钮类型 */
.primary {
  background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
  color: var(--text-inverse);
  box-shadow: var(--shadow-sm);
}

.primary:hover, .primary.hover {
  background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
  box-shadow: var(--shadow-md);
  transform: translateY(-2rpx);
}

.primary:active {
  background: linear-gradient(135deg, var(--primary-700), var(--primary-800));
  box-shadow: var(--shadow-xs);
  transform: translateY(0);
}

.secondary {
  background: var(--bg-primary);
  color: var(--primary-600);
  border: 2rpx solid var(--primary-300);
}

.secondary:hover, .secondary.hover {
  background: var(--primary-50);
  border-color: var(--primary-400);
  transform: translateY(-2rpx);
}

.secondary:active {
  background: var(--primary-100);
  border-color: var(--primary-500);
  transform: translateY(0);
}

.ghost {
  background: transparent;
  color: var(--text-primary);
  border: 2rpx solid var(--border-light);
}

.ghost:hover, .ghost.hover {
  background: var(--bg-tertiary);
  border-color: var(--border-medium);
  transform: translateY(-2rpx);
}

.ghost:active {
  background: var(--bg-secondary);
  border-color: var(--border-dark);
  transform: translateY(0);
}

.danger {
  background: linear-gradient(135deg, var(--error), #dc2626);
  color: var(--text-inverse);
  box-shadow: var(--shadow-sm);
}

.danger:hover, .danger.hover {
  background: linear-gradient(135deg, #dc2626, #b91c1c);
  box-shadow: var(--shadow-md);
  transform: translateY(-2rpx);
}

.danger:active {
  background: linear-gradient(135deg, #b91c1c, #991b1b);
  box-shadow: var(--shadow-xs);
  transform: translateY(0);
}

/* 按钮尺寸 */
.small {
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
  min-height: 64rpx;
  min-width: 120rpx;
}

.medium {
  padding: var(--space-3) var(--space-5);
  font-size: var(--text-base);
  border-radius: var(--radius-lg);
  min-height: 80rpx;
  min-width: 160rpx;
}

.large {
  padding: var(--space-4) var(--space-6);
  font-size: var(--text-lg);
  border-radius: var(--radius-xl);
  min-height: 96rpx;
  min-width: 200rpx;
}

/* 禁用状态 */
.disabled {
  opacity: 0.5;
  cursor: not-allowed;
  pointer-events: none;
}

.disabled:hover, .disabled.hover {
  transform: none;
  box-shadow: none;
}

/* 加载状态 */
.loading {
  cursor: wait;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-2);
}

.loading-spinner {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: currentColor;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.ghost .loading-spinner,
.secondary .loading-spinner {
  border-top-color: var(--primary-500);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 按钮内容 */
.btn-icon {
  margin-right: var(--space-2);
  font-size: 1.2em;
}

.btn-icon-right {
  margin-left: var(--space-2);
  font-size: 1.2em;
}

.btn-text {
  font-weight: var(--font-semibold);
  white-space: nowrap;
}

/* 涟漪效果 */
.custom-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s;
}

.custom-btn:active::after {
  width: 200rpx;
  height: 200rpx;
}

.ghost:active::after,
.secondary:active::after {
  background: rgba(14, 165, 233, 0.1);
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: var(--space-2);
}

.button-group .custom-btn {
  flex: 1;
  border-radius: 0;
}

.button-group .custom-btn:first-child {
  border-top-left-radius: var(--radius-lg);
  border-bottom-left-radius: var(--radius-lg);
}

.button-group .custom-btn:last-child {
  border-top-right-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);
}

/* 响应式调整 */
@media screen and (max-width: 600rpx) {
  .large {
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-base);
    min-height: 80rpx;
    min-width: 160rpx;
  }
  
  .medium {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    min-height: 72rpx;
    min-width: 140rpx;
  }
}