<!-- 按钮组件 -->
<button 
  class="custom-btn {{type}} {{size}} {{disabled ? 'disabled' : ''}} {{loading ? 'loading' : ''}}"
  style="{{customStyle}}"
  bindtap="{{!disabled && !loading ? 'onTap' : ''}}"
  hover-class="{{!disabled && !loading ? 'hover' : ''}}"
  hover-stay-time="100"
  loading="{{loading}}"
  disabled="{{disabled}}"
  form-type="{{formType}}"
  open-type="{{openType}}"
  plain="{{plain}}"
>
  <!-- 加载状态 -->
  <view class="btn-loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
  </view>
  
  <!-- 图标 -->
  <text class="btn-icon" wx:if="{{icon}}">{{icon}}</text>
  
  <!-- 文字内容 -->
  <text class="btn-text">{{text}}</text>
  
  <!-- 右侧图标 -->
  <text class="btn-icon-right" wx:if="{{iconRight}}">{{iconRight}}</text>
</button>