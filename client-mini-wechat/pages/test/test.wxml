<!-- 测试页面 -->
<view class="container">
  <view class="header">
    <text class="title">🧪 系统测试</text>
  </view>
  
  <view class="test-section">
    <text class="section-title">🔗 连接测试</text>
    
    <view class="test-card">
      <text class="test-name">云开发初始化</text>
      <text class="test-status {{cloudInitStatus}}">
        {{cloudInitStatus === 'success' ? '✅' : cloudInitStatus === 'fail' ? '❌' : '⏳'}}
        {{cloudInitText}}
      </text>
      <button class="test-btn" bindtap="testCloudInit" size="mini">
        测试
      </button>
    </view>
    
    <view class="test-card">
      <text class="test-name">数据库连接</text>
      <text class="test-status {{dbStatus}}">
        {{dbStatus === 'success' ? '✅' : dbStatus === 'fail' ? '❌' : '⏳'}}
        {{dbText}}
      </text>
      <button class="test-btn" bindtap="testDatabase" size="mini">
        测试
      </button>
    </view>
    
    <view class="test-card">
      <text class="test-name">云函数调用</text>
      <text class="test-status {{functionStatus}}">
        {{functionStatus === 'success' ? '✅' : functionStatus === 'fail' ? '❌' : '⏳'}}
        {{functionText}}
      </text>
      <button class="test-btn" bindtap="testCloudFunction" size="mini">
        测试
      </button>
    </view>
  </view>
  
  <view class="test-section">
    <text class="section-title">📱 功能测试</text>
    
    <view class="test-card">
      <text class="test-name">页面跳转</text>
      <view class="test-buttons">
        <button class="page-btn" bindtap="goToPage" data-page="word-list">
          单词列表
        </button>
        <button class="page-btn" bindtap="goToPage" data-page="word-add">
          添加单词
        </button>
        <button class="page-btn" bindtap="goToPage" data-page="index">
          首页
        </button>
      </view>
    </view>
    
    <view class="test-card">
      <text class="test-name">本地存储</text>
      <text class="test-status">{{storageText}}</text>
      <view class="test-buttons">
        <button class="page-btn" bindtap="testStorage" size="mini">
          测试存储
        </button>
        <button class="page-btn" bindtap="clearStorage" size="mini">
          清除存储
        </button>
      </view>
    </view>
  </view>
  
  <view class="test-section">
    <text class="section-title">📊 环境信息</text>
    
    <view class="info-card">
      <text class="info-item">环境ID: {{envInfo.envId || '未获取'}}</text>
      <text class="info-item">AppID: {{envInfo.appId || '未获取'}}</text>
      <text class="info-item">平台: {{envInfo.platform}}</text>
      <text class="info-item">版本: {{envInfo.version}}</text>
    </view>
  </view>
  
  <view class="action-buttons">
    <button class="btn primary-btn" bindtap="runAllTests">
      🚀 运行全部测试
    </button>
    <button class="btn" bindtap="goBack">
      返回
    </button>
  </view>
</view>