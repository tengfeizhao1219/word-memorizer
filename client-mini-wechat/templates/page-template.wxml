<!-- 页面模板 - 基于组件化架构 -->
<view class="page-container {{pageClass}}">
  <!-- 页面头部 -->
  <view class="page-header" wx:if="{{showHeader}}">
    <view class="header-content">
      <!-- 返回按钮 -->
      <view 
        class="back-btn" 
        bindtap="goBack"
        wx:if="{{showBackButton}}"
        hover-class="hover"
      >
        <text class="back-icon">←</text>
        <text class="back-text" wx:if="{{backText}}">{{backText}}</text>
      </view>
      
      <!-- 标题区域 -->
      <view class="title-area">
        <text class="page-title">{{pageTitle}}</text>
        <text class="page-subtitle" wx:if="{{pageSubtitle}}">{{pageSubtitle}}</text>
      </view>
      
      <!-- 操作按钮 -->
      <view class="header-actions">
        <slot name="header-actions"></slot>
      </view>
    </view>
  </view>
  
  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-content">
        <view class="loading-spinner"></view>
        <text class="loading-text">{{loadingText || '加载中...'}}</text>
      </view>
    </view>
    
    <!-- 错误状态 -->
    <view class="error-state" wx:if="{{error && !loading}}">
      <view class="error-content">
        <text class="error-icon">❌</text>
        <text class="error-title">{{errorTitle || '出错了'}}</text>
        <text class="error-desc">{{errorDesc || '加载页面时出现错误'}}</text>
        <custom-button 
          type="primary" 
          size="medium"
          text="重试"
          bind:click="onRetry"
          wx:if="{{showRetryButton}}"
        />
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{empty && !loading && !error}}">
      <view class="empty-content">
        <text class="empty-icon">{{emptyIcon || '📭'}}</text>
        <text class="empty-title">{{emptyTitle || '暂无数据'}}</text>
        <text class="empty-desc" wx:if="{{emptyDesc}}">{{emptyDesc}}</text>
        <slot name="empty-actions"></slot>
      </view>
    </view>
    
    <!-- 正常内容 -->
    <view class="normal-content" wx:if="{{!loading && !error && !empty}}">
      <slot></slot>
    </view>
  </view>
  
  <!-- 页面底部 -->
  <view class="page-footer" wx:if="{{showFooter}}">
    <slot name="footer"></slot>
  </view>
  
  <!-- 浮动操作按钮 -->
  <view class="fab-container" wx:if="{{showFAB}}">
    <custom-button 
      type="primary" 
      size="large"
      text="{{fabText}}"
      icon="{{fabIcon}}"
      bind:click="onFABClick"
      custom-style="border-radius: var(--radius-full); box-shadow: var(--shadow-lg);"
    />
  </view>
  
  <!-- 全局提示 -->
  <view class="toast-container" wx:if="{{showToast}}">
    <view class="toast {{toastType}}">
      <text class="toast-icon">
        <text wx:if="{{toastType === 'success'}}">✅</text>
        <text wx:if="{{toastType === 'error'}}">❌</text>
        <text wx:if="{{toastType === 'warning'}}">⚠️</text>
        <text wx:if="{{toastType === 'info'}}">ℹ️</text>
      </text>
      <text class="toast-text">{{toastMessage}}</text>
    </view>
  </view>
  
  <!-- 模态框 -->
  <view class="modal-overlay" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{modalTitle}}</text>
        <view class="modal-close" bindtap="closeModal">
          <text class="close-icon">×</text>
        </view>
      </view>
      <view class="modal-body">
        <slot name="modal-content"></slot>
      </view>
      <view class="modal-footer" wx:if="{{showModalFooter}}">
        <slot name="modal-footer"></slot>
      </view>
    </view>
  </view>
</view>